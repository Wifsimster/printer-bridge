# printcast configuration -- copy to .env and fill in.

# Network thermal printer (raw TCP / JetDirect). Leave PRINTER_HOST empty to
# auto-detect at startup (mDNS first, then a /24 subnet scan on PRINTER_PORT).
PRINTER_HOST=192.168.30.40
PRINTER_PORT=9100

# Set to false to disable startup auto-detection when PRINTER_HOST is empty.
PRINTER_AUTODETECT=true

# Codepage for French accents. CP858 is preferred; the service falls back to
# MagicEncode AUTO if the printer rejects this codepage name.
PRINTER_CODEPAGE=CP858

# Bearer token required on every /print* request. Required -- use a long random
# string, e.g. `openssl rand -hex 32`. Callers send: Authorization: Bearer <token>
PRINTER_TOKEN=change-me-to-a-long-random-secret

# Per-job socket timeout (seconds) and number of attempts per job.
PRINTER_TIMEOUT=20
PRINTER_RETRIES=3

# Local timezone, used for timestamps on receipts and the test print.
TZ=Europe/Paris
